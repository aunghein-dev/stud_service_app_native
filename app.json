{
  "expo": {
    "name": "Student Service App",
    "slug": "student-service-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f7f8f3"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aunghein.studentserviceapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#f7f8f3"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
